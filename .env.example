# NASA API Configuration
# Get your key at: https://api.nasa.gov/
NASA_API_KEY=your_nasa_api_key_here

# AVWX Aviation Weather Token
# Get your token at: https://account.avwx.rest/
AVWX_TOKEN=your_avwx_token_here

# Home Location Coordinates
# Default: Gütersloh, Germany
HOME_LAT=51.963
HOME_LON=8.534

# Data Files (optional, defaults shown)
DINO_DATA_FILE=dinos.json
SETTINGS_FILE=settings.json